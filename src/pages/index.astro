---
import Layout from "../layouts/Layout.astro";
import Skills from "../components/skill.astro";
import Projects from "../components/proyects.astro";
import Certificates from "../components/certificates.astro";
import { Image } from "astro:assets";
---

<Layout
  title="Nicolás Adrián Bernal Bermúdez | Desarrollador Multiplataforma"
  description="Portafolio profesional de Nicolás Adrián Bernal Bermúdez, estudiante de DAM especializado en desarrollo Frontend y Backend."
>
  <header
    class="relative w-full min-h-screen flex items-center justify-center overflow-hidden bg-[#0a0a0a] text-white px-6 py-20"
    id="home"
  >
    <div
      class="max-w-7xl mx-auto flex flex-col-reverse 2xl:flex-row items-center justify-between gap-12 w-full"
    >
      <div
        class="flex flex-col items-center 2xl:items-start text-center 2xl:text-left space-y-6 max-w-3xl"
      >
        <h1
          class="text-4xl md:text-6xl font-bold tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-white to-gray-400"
        >
          ¡Hola! Soy <span class="text-blue-400">Nicolás Bernal</span>
        </h1>

        <div class="space-y-4">
          <p class="text-lg md:text-xl text-gray-300 leading-relaxed">
            Especializado en crear soluciones robustas tanto en el <span
              class="text-blue-300">Frontend</span
            > como en el <span class="text-emerald-300">Backend</span>.
          </p>

          <p class="text-base md:text-lg text-gray-400 max-w-2xl">
            Experiencia con Java, Spring, JavaScript, Node.js, SQL, Astro,
            Tailwind CSS, entre otros. Enfocado en escribir código limpio y
            orientado a la mejor experiencia de usuario.
          </p>
        </div>

        <div class="flex flex-wrap justify-center 2xl:justify-start gap-4 pt-4">
          <a
            href="/Certificados/Curriculum_nicolas_bernal_bermudez.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-2 bg-white text-black px-8 py-3 rounded-full font-bold hover:bg-blue-400 hover:text-white transition-all duration-300 transform hover:-translate-y-1"
          >
            Descargar CV
            <i class="fa-solid fa-download group-hover:bounce"></i>
          </a>

          <a
            href="mailto:nicolasbernalbermudez@gmail.com"
            class="flex items-center gap-2 bg-transparent border border-white/20 px-8 py-3 rounded-full font-bold hover:bg-white/10 transition-all duration-300 transform hover:-translate-y-1"
          >
            Contacto
            <i class="fa-solid fa-envelope"></i>
          </a>
        </div>
      </div>

      <div class="relative group">
        <div
          class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-emerald-600 rounded-full blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"
        >
        </div>

        <Image
          src="/foto.jpeg"
          alt="Retrato de Nicolás Adrián Bernal Bermúdez"
          width={400}
          height={400}
          loading="eager"
          class="relative w-64 h-64 md:w-80 md:h-80 2xl:w-[400px] 2xl:h-[400px] rounded-full object-cover border-2 border-white/10 grayscale-[20%] hover:grayscale-0 transition-all duration-500 shadow-2xl"
        />
      </div>
    </div>
  </header>

  <main class="bg-[#0a0a0a]" id="projects">
    <section class="w-full bg-white/1">
      <Projects />
    </section>

    <section class="w-full bg-white/3" id="skills">
      <Skills />
    </section>

    <section class="w-full bg-white/1" id="certificates">
      <Certificates />
    </section>
  </main>
</Layout>

<style>
  /* Animación sutil para el fondo si decides usar fondoGuapoHeader */
  .fondoGuapoHeader {
    background: linear-gradient(
      45deg,
      rgba(255, 255, 255, 0.05) 0%,
      rgba(255, 255, 255, 0) 100%
    );
  }
</style>
