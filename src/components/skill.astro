---

<section
    class="flex flex-col justify-center items-center p-[2rem] md:p-[4rem] min-h-screen py-20 md:py-0"
    id="section-skill"
>
    <div class="fadeIn">
        <div>
            <h1 class="text-[40px] text-white text-center">Habilidades</h1>
        </div>
        <div
            class="flex flex-nowrap sm:flex-wrap md:flex-row justify-normal sm:justify-center items-center gap-0 sm:gap-[1.5rem] mt-[2rem] mx-0 sm:mx-[4rem] max-w-screen sm:max-w-[1100px] overflow-scroll sm:overflow-visible"
        >
            {
                skills.map((skill) => (
                    <article
                        class="my-[1.5rem] sm:my-0 mx-[1.5rem] sm:mx-0 parpadeo max-sm:flex-grow max-sm:flex-shrink-0 max-sm:basis-auto text-center items-center justify-center bg-transparent border border-white hover:bg-black w-[200px] sm:w-[120px] lg:w-[150px] h-[200px] sm:h-[120px] lg:h-[150px] transition-all duration-300 hover:scale-115"
                        style="box-shadow: 0px 0px 15px #ffffff29;"
                    >
                        <svg
                            stroke="currentColor"
                            class="icon text-white text-[170px] sm:text-[90px] lg:text-[120px] p-8"
                            fill="currentColor"
                            stroke-width="0"
                            viewBox={skill.viewBox}
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path d={skill.logo} />
                        </svg>
                    </article>
                ))
            }
            <article
                class="my-[1.5rem] sm:my-0 mx-[1.5rem] sm:mx-0 parpadeo max-sm:flex-grow max-sm:flex-shrink-0 max-sm:basis-auto text-center items-center justify-center bg-transparent border border-white hover:bg-black w-[200px] sm:w-[120px] lg:w-[150px] h-[200px] sm:h-[120px] lg:h-[150px] transition-all duration-300 hover:scale-115"
                style="box-shadow: 0px 0px 15px #ffffff29;"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    class="text-white text-[170px] sm:text-[90px] lg:text-[120px] p-8"
                    ><path
                        fill="none"
                        stroke="currentColor"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.5"
                        d="M4 18V6l10.5-4L20 4v16l-5.5 2zm0 0l10 .5V6L8.5 7.5v8z"
                        color="currentColor"></path></svg
                >
            </article>
            <article
                class="my-[1.5rem] sm:my-0 mx-[1.5rem] sm:mx-0 parpadeo max-sm:flex-grow max-sm:flex-shrink-0 max-sm:basis-auto sm:prueba-m text-center items-center justify-center bg-transparent border border-white hover:bg-black w-[200px] sm:w-[120px] lg:w-[150px] h-[200px] sm:h-[120px] lg:h-[150px] transition-all duration-300 hover:scale-115"
                style="box-shadow: 0px 0px 15px #ffffff29;"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="text-white text-[170px] sm:text-[90px] lg:text-[120px] p-8"
                    viewBox="0 0 24 24"
                    ><path
                        fill="currentColor"
                        fill-rule="evenodd"
                        d="M5 1a4 4 0 0 0-4 4v14a4 4 0 0 0 4 4h14a4 4 0 0 0 4-4V5a4 4 0 0 0-4-4zm2 5.5H6v10h2v-3h1.5a3.5 3.5 0 1 0 0-7zm2.5 5H8v-3h1.5a1.5 1.5 0 0 1 0 3m5-2.5v7.5h2v-4.25a2.35 2.35 0 0 1 .768-.824c.377-.242.921-.426 1.732-.426V9c-.976 0-1.807.196-2.5.56V9z"
                        clip-rule="evenodd"
                        stroke-width="0.5"
                        stroke="currentColor"></path></svg
                >
            </article>
        </div>
    </div>
</section>