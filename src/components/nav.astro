---
// Definimos los links en un array para no repetir código
const navLinks = [
  { name: "Home", href: "#home" },
  { name: "Proyectos", href: "#projects" }, // Corregido el ID a "projects"
  { name: "Habilidades", href: "#skills" },
  { name: "Certificados", href: "#certificates" },
];

const socials = [
  {
    icon: "fa-linkedin",
    href: "https://www.linkedin.com/in/nicol%C3%A1s-adri%C3%A1n-bernal-berm%C3%BAdez-666a35282/",
    label: "LinkedIn",
  },
  {
    icon: "fa-github",
    href: "https://github.com/nicolas181106",
    label: "GitHub",
  },
];
---

<nav
  class="main-nav fixed top-0 left-0 w-full z-50 transition-all duration-500 ease-in-out px-6 py-4 flex justify-center items-center"
>
  <div class="flex justify-between items-center w-full max-w-7xl">
    <div class="flex-1 lg:flex-none">
      <a
        href="#home"
        class="text-white font-black text-xl tracking-tighter hover:text-blue-400 transition-colors"
      >
        NICO<span class="text-blue-500">.</span>
      </a>
    </div>

    <ul class="hidden lg:flex gap-8 items-center justify-center flex-1">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm text-gray-300 font-medium hover:text-white transition-all relative after:content-[''] after:absolute after:w-0 after:h-[2px] after:bg-blue-500 after:left-0 after:-bottom-1 hover:after:w-full after:transition-all after:duration-300"
            >
              {link.name}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-4 flex-1 justify-end lg:flex-none">
      <div class="hidden lg:flex gap-3">
        {
          socials.map((social) => (
            <a
              href={social.href}
              target="_blank"
              aria-label={social.label}
              class="flex justify-center items-center w-10 h-10 border border-white/10 rounded-full text-white hover:bg-white hover:text-black transition-all duration-300"
            >
              <i class={`fa-brands ${social.icon}`} />
            </a>
          ))
        }
        <a
          href="mailto:nicolasbernalbermudez@gmail.com"
          target="_blank"
          aria-label="Email"
          class="flex justify-center items-center w-10 h-10 border border-white/10 rounded-full text-white hover:bg-white hover:text-black transition-all duration-300"
        >
          <i
            class="fa-solid fa-envelope text-lg group-hover:scale-110 transition-transform hidden"
          ></i>
        </a>
      </div>

      <button
        id="button-burger"
        class="lg:hidden text-white text-2xl p-2 focus:outline-none"
        aria-label="Menu"
      >
        <i class="fa-solid fa-bars-staggered" id="burger-icon"></i>
      </button>
    </div>
  </div>
</nav>

<div
  id="nav-overlay"
  class="fixed inset-0 bg-black/95 z-40 flex flex-col items-center justify-center transition-all duration-500 translate-x-full"
>
  <ul class="flex flex-col gap-8 text-center">
    {
      navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-link text-3xl text-white font-bold hover:text-blue-500 transition-colors"
          >
            {link.name}
          </a>
        </li>
      ))
    }
  </ul>

  <div class="flex gap-6 mt-12">
    {
      socials.map((social) => (
        <a
          href={social.href}
          class="text-white text-2xl hover:text-blue-500 transition-colors"
        >
          <i class={`fa-brands ${social.icon}`} />
        </a>
      ))
    }
  </div>
</div>

<script>
  const nav = document.getElementById("main-nav");
  const btn = document.getElementById("button-burger");
  const overlay = document.getElementById("nav-overlay");
  const icon = document.getElementById("burger-icon");
  const mobileLinks = document.querySelectorAll(".mobile-link");

  // 1. Efecto de Scroll (Cambia fondo al bajar)
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      nav?.classList.add(
        "backdrop-blur-md",
        "py-3",
        "border-b",
        "border-white/10",
      );
    } else {
      nav?.classList.remove(
        "backdrop-blur-md",
        "py-3",
        "border-b",
        "border-white/10",
      );
    }
  });

  // 2. Toggle Menú Mobile
  function toggleMenu() {
    overlay?.classList.toggle("translate-x-full");
    // Cambiar icono de burger a X
    icon?.classList.toggle("fa-bars-staggered");
    icon?.classList.toggle("fa-xmark");
    document.body.classList.toggle("overflow-hidden"); // Evita scroll al estar abierto
  }

  btn?.addEventListener("click", toggleMenu);

  // Cerrar menú al hacer clic en un link
  mobileLinks.forEach((link) => {
    link.addEventListener("click", toggleMenu);
  });
</script>

<style>
  /* Animación suave para la entrada de los links en mobile */
  #nav-overlay.flex ul li {
    animation: fadeIn 0.5s ease forwards;
    opacity: 0;
  }

  @keyframes fadeIn {
    from {
      transform: translateY(20px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @keyframes shrinkNav {
    to {
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
  }

  .main-nav {
    animation: shrinkNav linear both;
    animation-timeline: scroll(root);
    animation-range: 0px 100px;
  }
</style>
