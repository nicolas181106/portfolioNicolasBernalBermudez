---
import proyecto1 from "../assets/Img/Proyectos/TocadosAyaSevilla.png";
import proyecto2 from "../assets/Img/Proyectos/AgathaGatosPersa.png";
import proyecto3 from "../assets/Img/Proyectos/UtilWeb.png";

const proyects = [
    {
        name: "Tocados Aya Sevilla",
        img: proyecto1,
        url: "https://tocadosayasevilla.netlify.app/",
        description: "Sitio web para la venta de tocados, con un estilo elegante y moderno.",
        year: 2025,
        github: "https://github.com/nicolas181106/tocadosAyaSevilla"
    },
    {
        name: "Ágatha Gatos Persa",
        img: proyecto2,
        url: "https://agathagatospersa.netlify.app/",
        description: "Sitio web para la venta de gatos persas.",
        year: 2025,
        github: "https://github.com/nicolas181106/aghataGatosPersa"
    },
    {
        name: "Útil web",
        img: proyecto3,
        url: "https://utilweb.netlify.app/",
        description: "Sitio web con distintas herramientas.",
        year: 2025,
        github: "https://github.com/nicolas181106/tiempoWeb.git"
    },
];
---

<section
    class="flex justify-center items-center p-[2rem] md:p-[4rem] min-h-screen py-20 md:py-0 bg-neutral-900/20"
    id="section-proyect"
>
    <div class="fadeIn">
        <h1 class="text-[40px] text-white text-center">Proyectos</h1>
        <div
            class="flex flex-wrap justify-center items-center gap-[1.5rem] mt-[2rem]"
        >
            {
                proyects.map((proyecto) => (
                    <article
                        class="flex flex-col items-center p-4 rounded-[1rem] w-[300px] h-[400px] transition-all duration-300 hover:translate-y-[-0.5rem] fondoGuapo border-[1px] border-white/10"
                    >
                        <div>
                            <a href={proyecto.url} target="_blank">
                                <img
                                    src={
                                        typeof proyecto.img === "string"
                                            ? proyecto.img
                                            : proyecto.img.src
                                    }
                                    alt={proyecto.name}
                                    class="w-full h-[180px] rounded-[1rem] bg-white object-cover"
                                />
                            </a>
                        </div>
                        
                        <div class="flex flex-col items-start justify-start mt-[1rem] w-full h-full">
                            <h2 class="text-white text-[20px] text-left">{proyecto.name}</h2>
                            <p class="text-white text-[15px] mt-[0.5rem]">
                                {proyecto.description}
                            </p>
                            <div class="flex w-full items-center mt-[0.5rem]">
                                <span class="text-gray-400">{proyecto.year}</span>
                                <a href={proyecto.github} target="_blank">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="text-white w-[25px] hover:text-amber-300 hover:cursor-pointer ml-2" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2"/></svg>
                                </a>
                                <a href={proyecto.url} target="_blank">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="text-white w-[25px] hover:text-amber-300 hover:cursor-pointer ml-2" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-dasharray="28" stroke-dashoffset="28" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 6l2 -2c1 -1 3 -1 4 0l1 1c1 1 1 3 0 4l-5 5c-1 1 -3 1 -4 0M11 18l-2 2c-1 1 -3 1 -4 0l-1 -1c-1 -1 -1 -3 0 -4l5 -5c1 -1 3 -1 4 0"><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.6s" values="28;0"/></path></svg>
                                </a>
                            </div>
                        </div>

                        <div class="mt-[1rem] text-center justify-center flex gap-[0.5rem] w-full flex-wrap text-[15px]">
                            <a
                                href="#section-skill"
                                class="hover:bg-black py-1 px-2 flex items-center justify-center text-white rounded-[0.5rem] transition-all duration-300 border-[1px] border-white/10"
                            >
                                Astro
                            </a>
                            <a
                                href="#section-skill"
                                class="hover:bg-black py-1 px-2 flex items-center justify-center text-white rounded-[0.5rem] transition-all duration-300 border-[1px] border-white/10"
                            >
                                TailwindCSS
                            </a>
                            <a
                                href="#section-skill"
                                class="hover:bg-black py-1 px-2 flex items-center justify-center text-white rounded-[0.5rem] transition-all duration-300 border-[1px] border-white/10"
                            >
                                JavaScript
                            </a>
                        </div>
                    </article>
                ))
            }
        </div>
    </div>
</section>

<script is:inline>
    function setup(){
        createCanvas(windowWidth, windowHeight);
        }
        function draw(){
        background(150);
        noStroke();
        for(let i = 0; i<14000; i++){
            rect(random(width), random(height), 2, 2);
        }
        }
</script>