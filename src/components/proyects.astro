---
import { Image } from "astro:assets";
import proyecto1 from "../assets/Img/Proyectos/TocadosAyaSevilla.png";
import proyecto2 from "../assets/Img/Proyectos/AgathaGatosPersa.png";
import proyecto3 from "../assets/Img/Proyectos/UtilWeb.png";
import proyecto4 from "../assets/Img/Proyectos/agenex.png";

const projects = [
  {
    name: "Agenex",
    img: proyecto4,
    url: "",
    description:
      "Boilerplate corporativo desarrollado en equipo para proyectos empresariales seguros. Proporciona una arquitectura lista para producción con autenticación, roles y auditoría.",
    year: 2026,
    github: "https://github.com/nicolas181106/agenex.git",
    tags: ["Next.js", "TailwindCSS", "TypeScript", "PostgreSQL", "FastAPI"],
    accent: "from-red-500/20 to-red-500/5",
    accentBorder: "hover:border-red-500/50",
    accentTag: "text-red-300 bg-red-500/10 border-red-500/20",
    accentYear: "text-red-400",
  },
  {
    name: "Ágatha Gatos Persa",
    img: proyecto2,
    url: "https://agathagatospersas.es/",
    description:
      "Sitio web especializado en la cría y cuidado de gatos persas. Cuenta con una galería multimedia optimizada, secciones informativas y un diseño cálido totalmente responsivo.",
    year: 2025,
    github: "https://github.com/nicolas181106/aghataGatosPersa",
    tags: ["Astro", "TailwindCSS", "JavaScript"],
    accent: "from-amber-500/20 to-orange-500/5",
    accentBorder: "hover:border-amber-500/50",
    accentTag: "text-amber-300 bg-amber-500/10 border-amber-500/20",
    accentYear: "text-amber-400",
  },
  {
    name: "Tocados Aya Sevilla",
    img: proyecto1,
    url: "https://tocadosayasevilla.netlify.app/",
    description:
      "E-commerce elegante para la venta de tocados artesanales. Incluye catálogo dinámico y una experiencia de usuario optimizada para conversión.",
    year: 2025,
    github: "https://github.com/nicolas181106/tocadosAyaSevilla",
    tags: ["Astro", "TailwindCSS", "JavaScript"],
    accent: "from-violet-500/20 to-fuchsia-500/5",
    accentBorder: "hover:border-violet-500/50",
    accentTag: "text-violet-300 bg-violet-500/10 border-violet-500/20",
    accentYear: "text-violet-400",
  },
  {
    name: "Útil Web",
    img: proyecto3,
    url: "https://utilweb.netlify.app/",
    description:
      "Dashboard de herramientas web centralizadas. Integra utilidades cotidianas como consulta del clima en tiempo real, conversores de unidades y herramientas de productividad.",
    year: 2025,
    github: "https://github.com/nicolas181106/tiempoWeb.git",
    tags: ["Astro", "TailwindCSS", "JavaScript"],
    accent: "from-cyan-500/20 to-blue-500/5",
    accentBorder: "hover:border-cyan-500/50",
    accentTag: "text-cyan-300 bg-cyan-500/10 border-cyan-500/20",
    accentYear: "text-cyan-400",
  }
];
---

<section class="py-24 w-full">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Header -->
    <div class="flex flex-col items-center mb-16 gap-3">
      <span class="text-xs font-mono uppercase tracking-[0.3em] text-blue-400/70 border border-blue-500/20 px-4 py-1 rounded-full bg-blue-500/5">
        Trabajo
      </span>
      <h2 class="text-4xl md:text-5xl font-bold text-white text-center">
        Proyectos Recientes
      </h2>
      <p class="text-gray-500 text-sm max-w-md text-center">
        Proyectos reales construidos con tecnologías modernas del ecosistema web.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        projects.map((project, i) => (
          <article
            class={`group relative bg-neutral-900/60 border border-white/8 rounded-3xl overflow-hidden transition-all duration-300 flex flex-col ${project.accentBorder} hover:shadow-2xl hover:-translate-y-1`}
          >

            <div class="relative overflow-hidden aspect-video">
              <Image
                src={project.img}
                alt={project.name}
                class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-700"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-neutral-900 via-neutral-900/20 to-transparent" />
            </div>

            <!-- Content -->
            <div class="relative p-6 flex flex-col flex-grow">
              <div class="flex justify-between items-start mb-3">
                <h3 class="text-xl font-bold text-white leading-tight">{project.name}</h3>
                <span class={`text-sm font-mono font-bold ${project.accentYear}`}>
                  {project.year}
                </span>
              </div>

              <p class="text-gray-400 text-sm mb-5 flex-grow leading-relaxed">
                {project.description}
              </p>

              <!-- Tags -->
              <div class="flex flex-wrap gap-2 mb-5">
                {project.tags.map((tag) => (
                  <span class={`px-2.5 py-1 border rounded-full text-[10px] font-semibold uppercase tracking-wider ${project.accentTag}`}>
                    {tag}
                  </span>
                ))}
              </div>

              <!-- Footer links -->
              <div class="flex items-center justify-between border-t border-white/5 pt-4">
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2 text-gray-500 hover:text-white transition-colors text-sm group/gh"
                >
                  <i class="fa-brands fa-github text-lg group-hover/gh:scale-110 transition-transform" />
                  <span>Código</span>
                </a>
                {project.url ? (
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2 text-sm font-medium text-white/60 hover:text-white bg-white/5 hover:bg-white/10 px-4 py-1.5 rounded-full transition-all duration-200"
                >
                  Live demo
                  <i class="fa-solid fa-arrow-up-right-from-square text-xs" />
                </a> ) : (
                  <span class="text-gray-500 text-sm">
                    En Producción...
                  </span>
                )}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
