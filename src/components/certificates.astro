---
import html5 from "../assets/Img/Certificados/html5.png";
import cssmaquetado from "../assets/Img/Certificados/cssmaquetado.png";
import jsbasic from "../assets/Img/Certificados/jsbasic.png";
import vsc from "../assets/Img/Certificados/vsc.png";
import javadesde0 from "../assets/Img/Certificados/javadesde0.png";
import tailwindcss from "../assets/Img/Certificados/tailwindcss.png";
import angular from "../assets/Img/Certificados/angular.png";
// Asegúrate de importar los logos o imágenes para tus grados si los tienes, o usa placeholders temporales
// import logoDAM from "../assets/Img/Certificados/dam.png"; 
// import logoSMR from "../assets/Img/Certificados/smr.png";
import { Image } from "astro:assets";

// 1. TUS TITULACIONES PRINCIPALES (Mayor jerarquía)
const mainEducation = [
  {
    title: "Grado Superior en Desarrollo de Aplicaciones Multiplataforma (DAM)",
    institution: "Instituto de Formación Técnica", // Cambia por tu centro educativo
    date: "2024 - 2026",
    description: "Especialización en desarrollo de software, diseño de interfaces, gestión de bases de datos relacionales y sistemas asíncronos.",
    tags: ["Java", "Bases de Datos", "Sistemas", "Desarrollo Móvil/Web"],
    // url: "Certificados/titulo_dam.pdf" // Si quieres enlazar el título o expediente
  },
  {
    title: "Grado Medio en Sistemas Microinformáticos y Redes (SMR)",
    institution: "Instituto de Formación Técnica", // Cambia por tu centro educativo
    date: "2022 - 2024",
    description: "Formación base en montaje y mantenimiento de equipos, configuración de redes locales, servicios web y seguridad informática.",
    tags: ["Redes", "Sistemas Operativos", "Hardware", "Seguridad"],
    // url: "Certificados/titulo_smr.pdf"
  }
];

// 2. CURSOS COMPLEMENTARIOS (Menor jerarquía)
const certificates = [
  {
    name: "HTML5 y CSS3",
    logo: html5,
    url: "Certificados/certificado_curso_de_html5_y_css3.pdf",
    issuer: "OpenWebinars",
  },
  {
    name: "Maquetación web con CSS",
    logo: cssmaquetado,
    url: "Certificados/certificado_curso_de_maquetación_web_con_css.pdf",
    issuer: "OpenWebinars",
  },
  {
    name: "Fundamentos de JavaScript",
    logo: jsbasic,
    url: "Certificados/certificado_fundamentos_de_javascript.pdf",
    issuer: "OpenWebinars",
  },
  {
    name: "Visual Studio Code",
    logo: vsc,
    url: "Certificados/certificado_aumenta_tu_productividad_con_visual_studio_code.pdf",
    issuer: "OpenWebinars",
  },
  {
    name: "Java desde 0",
    logo: javadesde0,
    url: "Certificados/certificado_java_desde_0__introducción.pdf",
    issuer: "OpenWebinars",
  },
  {
    name: "TailwindCSS",
    logo: tailwindcss,
    url: "Certificados/certificado_tailwind_css.pdf",
    issuer: "OpenWebinars",
  },
  {
    name: "Fundamentos de Angular",
    logo: angular,
    url: "Certificados/certificado_fundamentos_de_angular.pdf",
    issuer: "OpenWebinars",
  },
];
---

<section class="py-24 w-full">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col items-center mb-16 gap-3">
      <span class="text-xs font-mono uppercase tracking-[0.3em] text-purple-400/70 border border-purple-500/20 px-4 py-1 rounded-full bg-purple-500/5">
        Formación
      </span>
      <h2 class="text-4xl md:text-5xl font-bold text-white text-center">
        Educación y Certificaciones
      </h2>
      <p class="text-gray-500 text-sm max-w-md text-center">
        Titulaciones oficiales y cursos de especialización técnica.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-20">
      {
        mainEducation.map((edu) => (
          <div class="relative bg-gradient-to-br from-neutral-900 via-neutral-900 to-neutral-950 border border-purple-500/20 rounded-3xl p-8 flex flex-col justify-between transition-all duration-300 hover:border-purple-500/50 hover:shadow-[0_0_30px_rgba(168,85,247,0.05)]">
            <div>
              <div class="flex justify-between items-start gap-4 mb-4">
                <h3 class="text-xl md:text-2xl font-bold text-white tracking-tight leading-snug">
                  {edu.title}
                </h3>
                <span class="text-xs font-mono bg-purple-500/10 border border-purple-500/20 text-purple-300 px-3 py-1 rounded-full shrink-0">
                  {edu.date}
                </span>
              </div>
              <p class="text-sm font-medium text-blue-400 mb-4">{edu.institution}</p>
              <p class="text-gray-400 text-sm leading-relaxed mb-6">
                {edu.description}
              </p>
            </div>
            
            <!-- Tags de las competencias del Grado -->
            <div class="flex flex-wrap gap-2 pt-4 border-t border-white/5">
              {edu.tags.map((tag) => (
                <span class="px-2.5 py-1 rounded-lg text-[11px] font-medium bg-white/5 text-gray-300 border border-white/10">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <div class="flex flex-col items-center lg:items-start mb-10">
      <h3 class="text-lg font-semibold text-gray-400 tracking-wide uppercase font-mono text-center lg:text-left">
        // Certificaciones Complementarias
      </h3>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      {
        certificates.map((cert, i) => (
          <a
            href={cert.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative bg-neutral-900 border border-white/10 rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:border-blue-500/40 flex flex-col"
          >
            <span class="absolute top-3 left-3 z-10 w-6 h-6 rounded-full bg-black/40 backdrop-blur-sm border border-white/10 flex items-center justify-center text-[10px] font-mono text-white/40 group-hover:text-white/70 transition-colors">
              {String(i + 1).padStart(2, "0")}
            </span>

            <span class="absolute top-3 right-3 z-10 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-1 group-hover:translate-y-0">
              <svg viewBox="0 0 24 24" class="w-4 h-4 text-white/60" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                <polyline points="15 3 21 3 21 9" />
                <line x1="10" y1="14" x2="21" y2="3" />
              </svg>
            </span>

            <div class="relative overflow-hidden aspect-[4/3] bg-black/20">
              <Image
                src={cert.logo}
                alt={cert.name}
                class="w-full h-full object-contain p-3 group-hover:scale-105 transition-transform duration-500"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
            </div>

            <div class="p-4 flex flex-col gap-2 flex-grow">
              <p class="text-white font-semibold text-sm leading-tight group-hover:text-white transition-colors">
                {cert.name}
              </p>
              <div class="flex items-center justify-between mt-auto pt-2 border-t border-white/5">
                <span class="text-[10px] font-medium px-2 py-0.5 rounded-full border text-blue-300 bg-blue-500/10 border-blue-500/20">
                  {cert.issuer}
                </span>
                <span class="text-[10px] text-gray-600 group-hover:text-gray-400 transition-colors uppercase tracking-widest font-mono">
                  Ver →
                </span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>